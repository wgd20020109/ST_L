(* ============================================================================
 * 文件: 01_03_DataTypeDemo.st
 * 章节: 第2章 - 变量声明与数据类型
 * 描述: 数据类型完整演示
 * 学习目标: 掌握ST语言所有基本数据类型
 * ============================================================================ *)

PROGRAM DataTypeDemo
VAR
    // ==========================================================================
    // 整数类型
    // ==========================================================================
    siValue : SINT;        // 8位有符号: -128 ~ 127
    usiValue : USINT;       // 8位无符号: 0 ~ 255
    iValue : INT;          // 16位有符号: -32768 ~ 32767
    uiValue : UINT;         // 16位无符号: 0 ~ 65535
    diValue : DINT;        // 32位有符号: ~21亿
    udiValue : UDINT;      // 32位无符号: 0 ~ 42亿
    liValue : LINT;        // 64位有符号
    luiValue : LUID;       // 64位无符号

    // ==========================================================================
    // 浮点数类型
    // ==========================================================================
    rSingle : REAL;        // 32位浮点
    lrDouble : LREAL;      // 64位浮点

    // ==========================================================================
    // 时间日期类型
    // ==========================================================================
    tDuration : TIME;          // 时间段
    dDate : DATE;              // 日期
    todTime : TIME_OF_DAY;     // 一天中的时间
    dtDateTime : DATE_AND_TIME; // 日期时间

    // ==========================================================================
    // 字符串类型
    // ==========================================================================
    sShort : STRING(10);
    sMedium : STRING(50);
    sLong : STRING(255);
    wsWide : WSTRING(100);     // 宽字符串

    // ==========================================================================
    // 位数据
    // ==========================================================================
    byByte : BYTE;         // 8位
    wWord : WORD;          // 16位
    dwDword : DWORD;       // 32位
    lwLword : LWORD;       // 64位

    // ==========================================================================
    // 布尔类型
    // ==========================================================================
    bTrue : BOOL := TRUE;
    bFalse : BOOL := FALSE;
    bOneZero : BOOL := 1;

    // ==========================================================================
    // 临时变量
    // ==========================================================================
    i : INT;
    rTemp : REAL;
    tTemp : TIME;
END_VAR

// ============================================================================
// 主程序逻辑
// ============================================================================
BEGIN
    // ==========================================================================
    // 1. 整数类型赋值
    // ==========================================================================
    siValue := 100;
    usiValue := 200;
    iValue := 30000;
    uiValue := 60000;
    diValue := 2000000000;
    udiValue := 4000000000;

    // 十六进制表示
    byByte := 16#FF;
    wWord := 16#ABCD;
    dwDword := 16#12345678;

    // 二进制表示
    byByte := 2#11110000;
    wWord := 2#1010101010101010;

    // ==========================================================================
    // 2. 浮点数赋值
    // ==========================================================================
    rSingle := 3.14159;
    lrDouble := 3.14159265358979323846;

    // 指数表示
    rSingle := 1.5E+10;     // 15000000000
    rSingle := 1.0E-6;      // 0.000001
    lrDouble := 2.0E+308;   // 非常大的数

    // ==========================================================================
    // 3. 时间类型赋值
    // ==========================================================================
    // 各种时间格式
    tDuration := T#1s;              // 1秒
    tDuration := T#500ms;          // 500毫秒
    tDuration := T#1m30s;          // 1分30秒
    tDuration := T#2h15m30s500ms;  // 2小时15分30秒500毫秒
    tDuration := tDuration + tDuration;  // 时间相加

    // 日期赋值
    dDate := D#2024-01-15;
    todTime := TOD#12:30:45.123;
    dtDateTime := DT#2024-01-15-12:30:45;

    // ==========================================================================
    // 4. 字符串赋值
    // ==========================================================================
    sShort := 'Hi';
    sMedium := 'This is a medium length string';
    sLong := 'This is a very long string that can hold up to 255 characters';

    // ==========================================================================
    // 5. 位访问
    // ==========================================================================
    byByte := 16#00;                   // 清除
    byByte.0 := TRUE;                  // 设置位0
    byByte.7 := TRUE;                  // 设置位7
    bTrue := byByte.0;                 // 读取位0

    wWord := 16#0000;
    wWord.0 := TRUE;                   // 位0
    wWord.15 := TRUE;                  // 位15 (最高位)

    // ==========================================================================
    // 6. 位操作
    // ==========================================================================
    byByte := 2#10101010;

    // 位与
    wWord := 16#F0F0 AND 16#0F0F;     // 结果: 16#0000

    // 位或
    wWord := 16#F0F0 OR 16#0F0F;      // 结果: 16#FFFF

    // 位异或
    wWord := 16#F0F0 XOR 16#FFFF;     // 结果: 16#0F0F

    // 位取反
    byByte := NOT 2#10101010;         // 结果: 2#01010101

    // 移位
    wWord := 2#0001 SHL 4;            // 左移4位: 2#00010000 = 16
    wWord := 2#10000 SHR 4;          // 右移4位: 2#0001 = 1

    // ==========================================================================
    // 7. 类型转换示例
    // ==========================================================================
    // INT -> REAL
    rTemp := INT_TO_REAL(100);        // 100.0

    // REAL -> INT (截断)
    iValue := REAL_TO_INT(3.9);      // 3

    // INT -> WORD (按位解释)
    wWord := INT_TO_WORD(256);       // 16#0100

    // WORD -> INT
    iValue := WORD_TO_INT(16#0100);  // 256

    // BOOL -> INT
    iValue := BOOL_TO_INT(TRUE);     // 1
    iValue := BOOL_TO_INT(FALSE);    // 0

    // INT -> BOOL (非零为TRUE)
    bTrue := INT_TO_BOOL(100);       // TRUE
    bFalse := INT_TO_BOOL(0);       // FALSE

    // ==========================================================================
    // 8. 数值范围展示
    // ==========================================================================
    siValue := 127;                   // SINT最大值
    siValue := -128;                  // SINT最小值
    usiValue := 255;                  // USINT最大值
    iValue := 32767;                  // INT最大值
    iValue := -32768;                 // INT最小值
    uiValue := 65535;                 // UINT最大值

END_PROGRAM
