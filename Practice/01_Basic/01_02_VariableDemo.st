(* ============================================================================
 * 文件: 01_02_VariableDemo.st
 * 章节: 第2章 - 变量声明与数据类型
 * 描述: 变量声明的完整演示
 * 学习目标: 掌握各种变量的声明方式
 * ============================================================================ *)

PROGRAM VariableDemo
VAR
    // ==========================================================================
    // 1. 基本数据类型声明
    // ==========================================================================

    // 布尔型变量
    bRunning : BOOL := FALSE;           // 带初始值
    bEnabled : BOOL;                    // 默认FALSE
    bFlag : BOOL := 1;                  // 也可用0/1赋值

    // 整数类型
    iCounter : INT := 0;               // 16位整数 -32,768~32,767
    iLargeCounter : DINT := 0;          // 32位整数
    iSmallValue : SINT := -10;         // 8位整数
    iPositive : UINT := 100;            // 无符号整数
    iByte : USINT := 255;               // 字节 0~255

    // 浮点数类型
    fRatio : REAL := 1.5;               // 单精度浮点
    fPi : LREAL := 3.14159265358979;    // 双精度浮点
    fVoltage : REAL := 220.5;           // 电压值
    fSpeed : LREAL := 1500.75;          // 电机转速

    // 时间类型
    tDelay : TIME := T#2s500ms;         // 延时时间
    tCycle : TIME := T#100ms;           // 周期
    tPowerOn : DATE := D#2024-01-01;    // 日期

    // 字符串类型
    sDeviceName : STRING(20) := 'Motor_A';
    sMessage : STRING(50) := 'System Ready';
    sEmpty : STRING(10);

    // 字节/字类型
    byData : BYTE := 16#AB;             // 十六进制
    wData : WORD := 2#1010101010101010; // 二进制
    dwData : DWORD := 16#12345678;       // 双字

    // ==========================================================================
    // 2. 数组声明
    // ==========================================================================

    // 一维数组
    aiTemperatures : ARRAY[1..7] OF INT := [23, 25, 22, 24, 26, 28, 27];
    abFlags : ARRAY[0..7] OF BOOL := [TRUE, FALSE, TRUE, FALSE, TRUE, FALSE, TRUE, FALSE];

    // 多维数组
    amMatrix : ARRAY[1..3, 1..3] OF INT := [1, 2, 3, 4, 5, 6, 7, 8, 9];

    // 字符串数组
    asDayNames : ARRAY[0..6] OF STRING(10) :=
        ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];

    // ==========================================================================
    // 3. 临时计算变量
    // ==========================================================================
    iTemp : INT;
    fTemp : REAL;
    bTemp : BOOL;
END_VAR

// ============================================================================
// 主程序逻辑
// ============================================================================
BEGIN
    // -------------------------------------------------------------------------
    // 1. 布尔运算
    // -------------------------------------------------------------------------
    bRunning := TRUE;
    bEnabled := bRunning AND NOT FALSE;     // 结果: TRUE
    bFlag := bRunning OR FALSE;             // 结果: TRUE
    bTemp := NOT bRunning;                  // 结果: FALSE

    // -------------------------------------------------------------------------
    // 2. 算术运算
    // -------------------------------------------------------------------------
    iCounter := 100 + 50;                   // 加法: 150
    iCounter := 100 - 30;                   // 减法: 70
    iCounter := 10 * 5;                     // 乘法: 50
    iCounter := 100 / 3;                    // 整数除法: 33
    iTemp := 100 MOD 3;                     // 取模: 1

    // -------------------------------------------------------------------------
    // 3. 数组访问
    // -------------------------------------------------------------------------
    iTemp := aiTemperatures[1];             // 第一个元素: 23
    iTemp := aiTemperatures[7];             // 最后一个元素: 27

    // 遍历数组计算平均值
    fTemp := 0.0;
    FOR iTemp := 1 TO 7 DO
        fTemp := fTemp + INT_TO_REAL(aiTemperatures[iTemp]);
    END_FOR;
    fTemp := fTemp / 7.0;                   // 平均温度

    // -------------------------------------------------------------------------
    // 4. 多维数组访问
    // -------------------------------------------------------------------------
    iTemp := amMatrix[1, 1];                 // 第一行第一列: 1
    iTemp := amMatrix[2, 2];                 // 第二行第二列: 5
    iTemp := amMatrix[3, 3];                 // 第三行第三列: 9

    // -------------------------------------------------------------------------
    // 5. 位操作
    // -------------------------------------------------------------------------
    byData := 2#10101010;                    // 设置初始值
    byData.0 := TRUE;                        // 设置最低位
    byData.7 := FALSE;                       // 设置最高位
    bTemp := byData.0;                      // 读取最低位

    // -------------------------------------------------------------------------
    // 6. 字符串操作（部分平台支持）
    // -------------------------------------------------------------------------
    sDeviceName := 'Pump_01';
    sMessage := CONCAT(sDeviceName, '_Running');

    // -------------------------------------------------------------------------
    // 7. 类型转换
    // -------------------------------------------------------------------------
    iTemp := 100;
    fTemp := INT_TO_REAL(iTemp);             // INT -> REAL: 100.0
    iTemp := REAL_TO_INT(3.7);               // REAL -> INT: 3 (截断)
    iTemp := ROUND(3.7);                    // 四舍五入: 4

    // -------------------------------------------------------------------------
    // 8. 变量赋值示例
    // -------------------------------------------------------------------------
    iCounter := iCounter + 1;               // 递增
    fRatio := fRatio * 1.1;                 // 乘以1.1

END_PROGRAM
