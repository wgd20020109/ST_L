(* ============================================================================
 * 文件: 01_04_OperatorDemo.st
 * 章节: 第3章 - 运算符与表达式
 * 描述: 运算符完整演示
 * 学习目标: 掌握ST语言所有运算符
 * ============================================================================ *)

PROGRAM OperatorDemo
VAR
    // ==========================================================================
    // 算术运算符演示
    // ==========================================================================
    iA, iB, iResult : INT;
    rX, rY, rResult : REAL;
    diLarge : DINT;

    // ==========================================================================
    // 比较运算符演示
    // ==========================================================================
    bCompare1, bCompare2, bCompare3 : BOOL;
    iValue : INT := 50;

    // ==========================================================================
    // 逻辑运算符演示
    // ==========================================================================
    bLogic1, bLogic2, bLogic3 : BOOL;
    bEnable, bRunning, bAlarm : BOOL;

    // ==========================================================================
    // 位运算符演示
    // ==========================================================================
    byData1, byData2, byResult : BYTE;
    wData, wMask : WORD;

    // ==========================================================================
    // 临时变量
    // ==========================================================================
    i : INT;
END_VAR

// ============================================================================
// 主程序逻辑
// ============================================================================
BEGIN
    // ==========================================================================
    // 1. 算术运算符
    // ==========================================================================
    iA := 20;
    iB := 6;

    // 加法
    iResult := iA + iB;               // 26

    // 减法
    iResult := iA - iB;               // 14

    // 乘法
    iResult := iA * iB;               // 120

    // 整数除法（截断小数）
    iResult := iA / iB;               // 3 (20 / 6 = 3.33...)

    // 取模（余数）
    iResult := iA MOD iB;            // 2 (20 % 6 = 2)

    // 幂运算
    iResult := 2 ** 10;               // 1024
    iResult := 3 ** 4;                // 81

    // ==========================================================================
    // 2. 浮点算术运算
    // ==========================================================================
    rX := 10.0;
    rY := 3.0;

    rResult := rX / rY;               // 3.3333...

    // 负数
    rResult := -rX;                   // -10.0

    // 复合运算
    rResult := (rX + rY) * (rX - rY); // (10+3) * (10-3) = 91

    // ==========================================================================
    // 3. 比较运算符
    // ==========================================================================
    iA := 10;
    iB := 20;

    // 等于
    bCompare1 := (iA = iB);           // FALSE

    // 不等于
    bCompare2 := (iA <> iB);          // TRUE

    // 小于
    bCompare3 := (iA < iB);           // TRUE

    // 大于
    bCompare1 := (iA > iB);           // FALSE

    // 小于等于
    bCompare2 := (iA <= iB);          // TRUE

    // 大于等于
    bCompare3 := (iA >= iB);          // FALSE

    // ==========================================================================
    // 4. 逻辑运算符
    // ==========================================================================
    bEnable := TRUE;
    bRunning := TRUE;
    bAlarm := FALSE;

    // 逻辑与 AND
    bLogic1 := bEnable AND bRunning;   // TRUE AND TRUE = TRUE
    bLogic1 := bEnable AND bAlarm;     // TRUE AND FALSE = FALSE

    // 逻辑或 OR
    bLogic2 := bAlarm OR bRunning;     // FALSE OR TRUE = TRUE
    bLogic2 := bAlarm OR NOT bRunning; // FALSE OR FALSE = FALSE

    // 逻辑异或 XOR
    bLogic3 := bEnable XOR bRunning;   // TRUE XOR TRUE = FALSE
    bLogic3 := bEnable XOR bAlarm;     // TRUE XOR FALSE = TRUE

    // 逻辑非 NOT
    bLogic1 := NOT bAlarm;             // NOT FALSE = TRUE
    bLogic1 := NOT bEnable;            // NOT TRUE = FALSE

    // 复杂逻辑表达式
    bLogic1 := (bEnable AND bRunning) OR bAlarm;          // TRUE
    bLogic1 := bEnable AND (bRunning OR bAlarm);           // TRUE
    bLogic1 := NOT bAlarm AND (bEnable OR bRunning);      // TRUE

    // ==========================================================================
    // 5. 位运算符
    // ==========================================================================
    byData1 := 2#10101010;    // 170
    byData2 := 2#11001100;    // 204

    // 位与
    byResult := byData1 AND byData2;
    // 10101010
    // 11001100
    // --------
    // 10001000 = 136

    // 位或
    byResult := byData1 OR byData2;
    // 10101010
    // 11001100
    // --------
    // 11101110 = 238

    // 位异或
    byResult := byData1 XOR byData2;
    // 10101010
    // 11001100
    // --------
    // 01100110 = 102

    // 位取反
    byResult := NOT byData1;
    // NOT 10101010 = 01010101 = 85

    // ==========================================================================
    // 6. 移位运算符
    // ==========================================================================
    byData1 := 2#00000001;    // 1

    // 左移
    byResult := byData1 SHL 1;    // 2  (00000010)
    byResult := byData1 SHL 2;    // 4  (00000100)
    byResult := byData1 SHL 4;    // 16 (00010000)
    byResult := byData1 SHL 7;    // 128 (10000000)

    // 右移
    byData1 := 2#10000000;    // 128
    byResult := byData1 SHR 1;    // 64 (01000000)
    byResult := byData1 SHR 2;    // 32 (00100000)
    byResult := byData1 SHR 4;    // 8  (00001000)

    // ==========================================================================
    // 7. 复合表达式
    // ==========================================================================
    iA := 10;
    iB := 20;
    rX := 2.5;

    // 运算优先级: NOT > AND > OR
    // 1 + 2 * 3 - 4 / 2
    iResult := 1 + 2 * 3 - 4 / 2;     // 1 + 6 - 2 = 5

    // 使用括号明确优先级
    iResult := ((1 + 2) * (3 - 4)) / 2;   // (3 * -1) / 2 = -1

    // 混合类型
    rResult := INT_TO_REAL(iA) / INT_TO_REAL(iB) * rX;
    // 10.0 / 20.0 * 2.5 = 1.25

    // ==========================================================================
    // 8. 实用计算示例
    // ==========================================================================

    // 计算圆的面积
    rX := 5.0;                         // 半径
    rResult := 3.14159 * rX * rX;     // 面积 = πr²

    // 计算两点距离
    rX := 3.0;   // x1
    rY := 4.0;   // y1
    // 假设 x2=0, y2=0
    rResult := SQRT(rX * rX + rY * rY);  // 距离 = 5

    // 摄氏度转华氏度
    rX := 25.0;                               // 25°C
    rResult := rX * 9.0 / 5.0 + 32.0;       // 77°F

    // 位掩码操作
    wData := 16#ABCD;
    wMask := 16#00FF;

    // 提取低字节
    byResult := LOW_BYTE(wData AND wMask);    // 16#CD

    // 提取高字节
    wMask := 16#FF00;
    byResult := HIGH_BYTE((wData AND wMask) SHR 8);  // 16#AB

END_PROGRAM
