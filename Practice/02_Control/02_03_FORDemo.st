(* ============================================================================
 * 文件: 02_03_FORDemo.st
 * 章节: 第5章 - 循环控制语句
 * 描述: FOR循环完整演示
 * 学习目标: 掌握FOR循环的各种用法
 * ============================================================================ *)

PROGRAM FORDemo
VAR
    // ==========================================================================
    // 数组操作变量
    // ==========================================================================
    aiData : ARRAY[1..10] OF INT := [5, 2, 8, 1, 9, 3, 7, 4, 6, 10];
    aiTemperatures : ARRAY[1..24] OF INT;
    i : INT;
    iSum : DINT;
    iMax, iMin : INT;
    iMaxIndex, iMinIndex : INT;

    // ==========================================================================
    // 数学计算变量
    // ==========================================================================
    iFactorial : DINT;
    iFibonacci : DINT;
    iN : INT := 10;
    rPiApprox : REAL;
    rEApprox : REAL;

    // ==========================================================================
    // 多维数组变量
    // ==========================================================================
    amMatrix : ARRAY[1..3, 1..3] OF INT;
    amResult : ARRAY[1..3, 1..3] OF INT;

    // ==========================================================================
    // 搜索变量
    // ==========================================================================
    iTarget : INT := 7;
    bFound : BOOL := FALSE;
    iFoundIndex : INT := 0;

    // ==========================================================================
    // 临时变量
    // ==========================================================================
    rTemp : REAL;
    j, k : INT;
END_VAR

// ============================================================================
// 主程序逻辑
// ============================================================================
BEGIN
    // ==========================================================================
    // 1. 简单FOR循环 - 计算1+2+3+...+100
    // ==========================================================================

    iSum := 0;
    FOR i := 1 TO 100 DO
        iSum := iSum + i;
    END_FOR
    // iSum = 5050

    // ==========================================================================
    // 2. 逆序FOR循环
    // ==========================================================================

    iSum := 0;
    FOR i := 100 TO 1 BY -1 DO
        iSum := iSum + i;
    END_FOR
    // iSum = 5050

    // ==========================================================================
    // 3. 步长为2的FOR循环 - 计算偶数和
    // ==========================================================================

    iSum := 0;
    FOR i := 2 TO 100 BY 2 DO
        iSum := iSum + i;
    END_FOR
    // iSum = 2550

    // ==========================================================================
    // 4. 数组求和
    // ==========================================================================

    iSum := 0;
    FOR i := 1 TO 10 DO
        iSum := iSum + aiData[i];
    END_FOR
    // iSum = 55

    // ==========================================================================
    // 5. 查找最大值和最小值
    // ==========================================================================

    iMax := aiData[1];
    iMin := aiData[1];
    iMaxIndex := 1;
    iMinIndex := 1;

    FOR i := 2 TO 10 DO
        IF aiData[i] > iMax THEN
            iMax := aiData[i];
            iMaxIndex := i;
        END_IF
        IF aiData[i] < iMin THEN
            iMin := aiData[i];
            iMinIndex := i;
        END_IF
    END_FOR
    // iMax = 10, iMaxIndex = 10
    // iMin = 1, iMinIndex = 4

    // ==========================================================================
    // 6. 搜索数组中特定值
    // ==========================================================================

    bFound := FALSE;
    iFoundIndex := 0;

    FOR i := 1 TO 10 DO
        IF aiData[i] = iTarget THEN
            bFound := TRUE;
            iFoundIndex := i;
            EXIT;  (* 找到后提前退出 *)
        END_IF
    END_FOR
    // bFound = TRUE, iFoundIndex = 7

    // ==========================================================================
    // 7. 计算阶乘
    // ==========================================================================

    iN := 10;
    iFactorial := 1;
    FOR i := 1 TO iN DO
        iFactorial := iFactorial * INT_TO_DINT(i);
    END_FOR
    // iFactorial = 3628800

    // ==========================================================================
    // 8. 计算斐波那契数列
    // ==========================================================================

    iN := 10;
    VAR aiFib : ARRAY[1..20] OF DINT; END_VAR

    aiFib[1] := 1;
    aiFib[2] := 1;

    FOR i := 3 TO iN DO
        aiFib[i] := aiFib[i-1] + aiFib[i-2];
    END_FOR
    // aiFib[10] = 55

    // ==========================================================================
    // 9. 计算圆周率（莱布尼茨公式）
    // ==========================================================================

    rPiApprox := 0.0;
    FOR i := 0 TO 1000 DO
        IF (i MOD 2) = 0 THEN
            rPiApprox := rPiApprox + 4.0 / INT_TO_REAL(2 * i + 1);
        ELSE
            rPiApprox := rPiApprox - 4.0 / INT_TO_REAL(2 * i + 1);
        END_IF
    END_FOR
    // rPiApprox ≈ 3.14159

    // ==========================================================================
    // 10. 嵌套FOR循环 - 矩阵初始化
    // ==========================================================================

    FOR i := 1 TO 3 DO
        FOR j := 1 TO 3 DO
            amMatrix[i, j] := i * 10 + j;
        END_FOR
    END_FOR
    // amMatrix = [[11, 12, 13], [21, 22, 23], [31, 32, 33]]

    // ==========================================================================
    // 11. 嵌套FOR循环 - 矩阵加法
    // ==========================================================================

    FOR i := 1 TO 3 DO
        FOR j := 1 TO 3 DO
            amResult[i, j] := amMatrix[i, j] + amMatrix[i, j];
        END_FOR
    END_FOR
    // amResult = [[22, 24, 26], [42, 44, 46], [62, 64, 66]]

    // ==========================================================================
    // 12. 生成24小时温度数据（模拟）
    // ==========================================================================

    FOR i := 1 TO 24 DO
        // 模拟温度：凌晨低，中午高
        IF i <= 6 THEN
            aiTemperatures[i] := 15 + i;
        ELSIF i <= 12 THEN
            aiTemperatures[i] := 20 + (i - 6);
        ELSIF i <= 18 THEN
            aiTemperatures[i] := 28 - (i - 12);
        ELSE
            aiTemperatures[i] := 22 - (i - 18);
        END_IF
    END_FOR

    // ==========================================================================
    // 13. 条件累加 - 只累加正数
    // ==========================================================================

    iSum := 0;
    FOR i := 1 TO 10 DO
        IF aiData[i] > 0 THEN
            iSum := iSum + aiData[i];
        END_IF
    END_FOR

    // ==========================================================================
    // 14. 跳过特定值 - CONTINUE用法
    // ==========================================================================

    iSum := 0;
    FOR i := 1 TO 10 DO
        IF aiData[i] = 5 THEN
            CONTINUE;  (* 跳过值5 *)
        END_IF
        iSum := iSum + aiData[i];
    END_FOR
    // iSum = 50 (跳过了一个5)

    // ==========================================================================
    // 15. 计算数组平均值和标准差
    // ==========================================================================

    VAR
        rMean : REAL;
        rVariance : REAL;
        rStdDev : REAL;
        aiSample : ARRAY[1..10] OF INT := [10, 12, 23, 23, 16, 23, 21, 16, 18, 22];
    END_VAR

    (* 计算平均值 *)
    iSum := 0;
    FOR i := 1 TO 10 DO
        iSum := iSum + aiSample[i];
    END_FOR
    rMean := DINT_TO_REAL(iSum) / 10.0;

    (* 计算方差 *)
    rVariance := 0.0;
    FOR i := 1 TO 10 DO
        rTemp := INT_TO_REAL(aiSample[i]) - rMean;
        rVariance := rVariance + rTemp * rTemp;
    END_FOR
    rVariance := rVariance / 10.0;

    (* 计算标准差 *)
    rStdDev := SQRT(rVariance);

END_PROGRAM
