(* ============================================================================
 * 函数: Add
 * 功能: 两个整数相加
 * ============================================================================ *)
FUNCTION Add : INT
VAR_INPUT
    a : INT;
    b : INT;
END_VAR

BEGIN
    Add := a + b;
END_FUNCTION

(* ============================================================================
 * 函数: Subtract
 * 功能: 两个整数相减
 * ============================================================================ *)
FUNCTION Subtract : INT
VAR_INPUT
    a : INT;
    b : INT;
END_VAR

BEGIN
    Subtract := a - b;
END_FUNCTION

(* ============================================================================
 * 函数: Multiply
 * 功能: 两个整数相乘
 * ============================================================================ *)
FUNCTION Multiply : INT
VAR_INPUT
    a : INT;
    b : INT;
END_VAR

BEGIN
    Multiply := a * b;
END_FUNCTION

(* ============================================================================
 * 函数: SafeDivide
 * 功能: 安全的整数除法（防止除零）
 * ============================================================================ *)
FUNCTION SafeDivide : INT
VAR_INPUT
    dividend : INT;
    divisor : INT;
END_VAR

BEGIN
    IF divisor <> 0 THEN
        SafeDivide := dividend / divisor;
    ELSE
        SafeDivide := 0;  (* 除零时返回0 *)
    END_IF
END_FUNCTION

(* ============================================================================
 * 函数: Max2
 * 功能: 返回两个数中的最大值
 * ============================================================================ *)
FUNCTION Max2 : INT
VAR_INPUT
    a : INT;
    b : INT;
END_VAR

BEGIN
    IF a > b THEN
        Max2 := a;
    ELSE
        Max2 := b;
    END_IF
END_FUNCTION

(* ============================================================================
 * 函数: Min2
 * 功能: 返回两个数中的最小值
 * ============================================================================ *)
FUNCTION Min2 : INT
VAR_INPUT
    a : INT;
    b : INT;
END_VAR

BEGIN
    IF a < b THEN
        Min2 := a;
    ELSE
        Min2 := b;
    END_IF
END_FUNCTION

(* ============================================================================
 * 函数: Max3
 * 功能: 返回三个数中的最大值
 * ============================================================================ *)
FUNCTION Max3 : INT
VAR_INPUT
    a : INT;
    b : INT;
    c : INT;
END_VAR
VAR
    temp : INT;
END_VAR

BEGIN
    temp := Max2(a, b);
    Max3 := Max2(temp, c);
END_FUNCTION

(* ============================================================================
 * 函数: IsInRange
 * 功能: 判断值是否在指定范围内
 * ============================================================================ *)
FUNCTION IsInRange : BOOL
VAR_INPUT
    value : INT;
    min : INT;
    max : INT;
END_VAR

BEGIN
    IsInRange := (value >= min) AND (value <= max);
END_FUNCTION

(* ============================================================================
 * 函数: Clamp
 * 功能: 将值限制在指定范围内
 * ============================================================================ *)
FUNCTION Clamp : INT
VAR_INPUT
    value : INT;
    min : INT;
    max : INT;
END_VAR

BEGIN
    IF value < min THEN
        Clamp := min;
    ELSIF value > max THEN
        Clamp := max;
    ELSE
        Clamp := value;
    END_IF
END_FUNCTION

(* ============================================================================
 * 函数: AbsDiff
 * 功能: 计算两个数的绝对差值
 * ============================================================================ *)
FUNCTION AbsDiff : INT
VAR_INPUT
    a : INT;
    b : INT;
END_VAR
VAR
    diff : INT;
END_VAR

BEGIN
    diff := a - b;
    IF diff < 0 THEN
        AbsDiff := -diff;
    ELSE
        AbsDiff := diff;
    END_IF
END_FUNCTION

(* ============================================================================
 * 函数: CelsiusToFahrenheit
 * 功能: 摄氏度转华氏度
 * ============================================================================ *)
FUNCTION CelsiusToFahrenheit : REAL
VAR_INPUT
    celsius : REAL;
END_VAR

BEGIN
    CelsiusToFahrenheit := celsius * 9.0 / 5.0 + 32.0;
END_FUNCTION

(* ============================================================================
 * 函数: FahrenheitToCelsius
 * 功能: 华氏度转摄氏度
 * ============================================================================ *)
FUNCTION FahrenheitToCelsius : REAL
VAR_INPUT
    fahrenheit : REAL;
END_VAR

BEGIN
    FahrenheitToCelsius := (fahrenheit - 32.0) * 5.0 / 9.0;
END_FUNCTION

(* ============================================================================
 * 函数: CircleArea
 * 功能: 计算圆面积
 * ============================================================================ *)
FUNCTION CircleArea : REAL
VAR_INPUT
    radius : REAL;
END_VAR

BEGIN
    IF radius < 0.0 THEN
        CircleArea := 0.0;
    ELSE
        CircleArea := 3.14159 * radius * radius;
    END_IF
END_FUNCTION

(* ============================================================================
 * 函数: CircleCircumference
 * 功能: 计算圆周长
 * ============================================================================ *)
FUNCTION CircleCircumference : REAL
VAR_INPUT
    radius : REAL;
END_VAR

BEGIN
    IF radius < 0.0 THEN
        CircleCircumference := 0.0;
    ELSE
        CircleCircumference := 2.0 * 3.14159 * radius;
    END_IF
END_FUNCTION

(* ============================================================================
 * 函数: Distance2D
 * 功能: 计算两点间的距离
 * ============================================================================ *)
FUNCTION Distance2D : REAL
VAR_INPUT
    x1 : REAL;
    y1 : REAL;
    x2 : REAL;
    y2 : REAL;
END_VAR
VAR
    dx, dy : REAL;
END_VAR

BEGIN
    dx := x2 - x1;
    dy := y2 - y1;
    Distance2D := SQRT(dx * dx + dy * dy);
END_FUNCTION

(* ============================================================================
 * 程序: FunctionDemo
 * 功能: 函数演示主程序
 * ============================================================================ *)
PROGRAM FunctionDemo
VAR
    iResult : INT;
    rResult : REAL;
    bResult : BOOL;
    x1, y1, x2, y2 : REAL;
END_VAR

BEGIN
    // ==========================================================================
    // 1. 基本算术函数
    // ==========================================================================

    iResult := Add(10, 20);              // 30
    iResult := Subtract(30, 15);         // 15
    iResult := Multiply(6, 7);           // 42
    iResult := SafeDivide(100, 3);       // 33
    iResult := SafeDivide(100, 0);       // 0 (除零保护)

    // ==========================================================================
    // 2. 比较函数
    // ==========================================================================

    iResult := Max2(10, 20);             // 20
    iResult := Min2(10, 20);             // 10
    iResult := Max3(10, 30, 20);         // 30

    // ==========================================================================
    // 3. 范围判断
    // ==========================================================================

    bResult := IsInRange(50, 0, 100);    // TRUE
    bResult := IsInRange(150, 0, 100);   // FALSE

    // ==========================================================================
    // 4. 限幅
    // ==========================================================================

    iResult := Clamp(150, 0, 100);       // 100
    iResult := Clamp(-10, 0, 100);       // 0
    iResult := Clamp(50, 0, 100);        // 50

    // ==========================================================================
    // 5. 绝对差值
    // ==========================================================================

    iResult := AbsDiff(100, 80);        // 20
    iResult := AbsDiff(80, 100);        // 20
    iResult := AbsDiff(50, 50);         // 0

    // ==========================================================================
    // 6. 温度转换
    // ==========================================================================

    rResult := CelsiusToFahrenheit(0.0);     // 32.0
    rResult := CelsiusToFahrenheit(100.0);   // 212.0
    rResult := CelsiusToFahrenheit(37.0);    // 98.6

    rResult := FahrenheitToCelsius(32.0);    // 0.0
    rResult := FahrenheitToCelsius(212.0);   // 100.0

    // ==========================================================================
    // 7. 几何计算
    // ==========================================================================

    rResult := CircleArea(5.0);              // 78.54
    rResult := CircleCircumference(5.0);     // 31.42
    rResult := CircleArea(-5.0);             // 0.0 (非法输入)

    // ==========================================================================
    // 8. 距离计算
    // ==========================================================================

    x1 := 0.0; y1 := 0.0;
    x2 := 3.0; y2 := 4.0;
    rResult := Distance2D(x1, y1, x2, y2);  // 5.0

    x1 := 1.0; y1 := 1.0;
    x2 := 4.0; y2 := 5.0;
    rResult := Distance2D(x1, y1, x2, y2); // 5.0

    // ==========================================================================
    // 9. 函数组合使用
    // ==========================================================================

    // 计算并限幅: (100 + 200) 不能超过 500
    iResult := Clamp(Add(100, 200), 0, 500);  // 300

    // 计算两点距离后判断
    rResult := Distance2D(0.0, 0.0, 3.0, 4.0);
    bResult := IsInRange(REAL_TO_INT(rResult), 0, 10);  // TRUE

    // 温度转换组合
    rResult := CelsiusToFahrenheit(FahrenheitToCelsius(100.0));  // 100.0

END_PROGRAM
