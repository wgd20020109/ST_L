(* ============================================================================
 * 文件: 07_02_TypeConversion.st
 * 章节: 第10章 - 高级特性
 * 描述: 类型转换演示
 * 学习目标: 掌握各种类型转换函数
 * ============================================================================ *)

PROGRAM TypeConversionDemo
VAR
    // ==========================================================================
    // 整数转换
    // ==========================================================================
    siValue : SINT := 100;
    iValue : INT := 1000;
    diValue : DINT := 1000000;
    uiValue : UINT := 65535;
    usiValue : USINT := 255;

    // ==========================================================================
    // 浮点数转换
    // ==========================================================================
    rValue : REAL := 3.14159;
    lrValue : LREAL := 3.14159265358979;

    // ==========================================================================
    // 布尔转换
    // ==========================================================================
    bTrue : BOOL := TRUE;
    bFalse : BOOL := FALSE;
    bValue : BOOL;

    // ==========================================================================
    // 字符串
    // ==========================================================================
    sText : STRING(50);
    sNumber : STRING(20);

    // ==========================================================================
    // 时间转换
    // ==========================================================================
    tDuration : TIME := T#5s250ms;
    tMilliseconds : INT;

    // ==========================================================================
    // 位数据
    // ==========================================================================
    byByte : BYTE;
    wWord : WORD;
    dwDword : DWORD;

    // ==========================================================================
    // 结果变量
    // ==========================================================================
    rResult : REAL;
    iResult : INT;
    bResult : BOOL;
    sResult : STRING(50);
END_VAR

// ============================================================================
// 主程序逻辑
// ============================================================================
BEGIN
    // ==========================================================================
    // 1. 整数类型之间的转换
    // ==========================================================================

    // SINT -> INT
    iResult := SINT_TO_INT(siValue);    // 100

    // INT -> DINT
    rResult := INT_TO_DINT(iValue);     // 1000000

    // DINT -> INT (可能溢出)
    iResult := DINT_TO_INT(diValue);    // 可能截断

    // USINT -> UINT
    uiValue := USINT_TO_UINT(usiValue); // 255

    // UINT -> USINT (可能截断)
    usiValue := UINT_TO_USINT(uiValue); // 255

    // ==========================================================================
    // 2. 整数与实数之间的转换
    // ==========================================================================

    // INT -> REAL
    rResult := INT_TO_REAL(iValue);      // 1000.0

    // INT -> LREAL
    rResult := INT_TO_LREAL(iValue);     // 1000.0

    // REAL -> INT (截断小数部分)
    iResult := REAL_TO_INT(rValue);      // 3

    // REAL -> DINT
    // diValue := REAL_TO_DINT(rValue);

    // REAL -> LREAL
    lrValue := REAL_TO_LREAL(rValue);    // 3.14159

    // LREAL -> REAL (可能丢失精度)
    rValue := LREAL_TO_REAL(lrValue);

    // ==========================================================================
    // 3. 取整函数
    // ==========================================================================

    rValue := 3.7;

    // TRUNC: 截断
    iResult := TRUNC(rValue);            // 3

    // ROUND: 四舍五入
    iResult := ROUND(rValue);            // 4

    // CEIL: 向上取整
    rResult := CEIL(3.2);              // 4.0

    // FLOOR: 向下取整
    rResult := FLOOR(3.9);              // 3.0

    // ==========================================================================
    // 4. 布尔与整数之间的转换
    // ==========================================================================

    // BOOL -> INT
    iResult := BOOL_TO_INT(TRUE);        // 1
    iResult := BOOL_TO_INT(FALSE);       // 0

    // INT -> BOOL (非零=TRUE, 零=FALSE)
    bValue := INT_TO_BOOL(100);          // TRUE
    bValue := INT_TO_BOOL(0);            // FALSE

    // ==========================================================================
    // 5. 字符串转换
    // ==========================================================================

    // INT -> STRING
    sText := INT_TO_STRING(12345);       // '12345'

    // REAL -> STRING (某些平台)
    // sText := REAL_TO_STRING(3.14);

    // STRING -> INT (某些平台)
    iResult := STRING_TO_INT('456');      // 456

    // STRING -> REAL (某些平台)
    rResult := STRING_TO_REAL('3.14');   // 3.14

    // ==========================================================================
    // 6. 时间类型转换
    // ==========================================================================

    // TIME -> 毫秒
    tMilliseconds := TIME_TO_MS(tDuration);  // 5250

    // 毫秒 -> TIME
    // tDuration := MS_TO_TIME(1000);         // T#1s

    // TIME -> 秒 (REAL)
    rResult := TIME_TO_REAL(tDuration) / 1000.0;  // 5.25

    // TIME组件提取
    VAR tTemp : TIME; END_VAR
    VAR iHours, iMinutes, iSeconds, iMS : INT; END_VAR

    tTemp := tDuration;
    // 注意: 实际提取需要根据平台实现

    // ==========================================================================
    // 7. 位数据转换
    // ==========================================================================

    // BYTE -> WORD
    wWord := BYTE_TO_WORD(byByte);       // 扩展为16位

    // WORD -> BYTE (取低字节)
    byByte := WORD_TO_BYTE(wWord);

    // WORD -> DWORD
    dwDword := WORD_TO_DWORD(wWord);     // 扩展为32位

    // DWORD -> WORD
    wWord := DWORD_TO_WORD(dwDword);     // 取低16位

    // INT -> WORD (按位解释)
    wWord := INT_TO_WORD(256);           // 16#0100

    // WORD -> INT
    iResult := WORD_TO_INT(wWord);       // 256

    // ==========================================================================
    // 8. BYTE位操作
    // ==========================================================================

    byByte := 16#AB;                     // 10101011

    // 提取高4位
    VAR byHighNibble : BYTE; END_VAR
    byHighNibble := (byByte AND 16#F0) SHR 4;  // 16#0A

    // 提取低4位
    VAR byLowNibble : BYTE; END_VAR
    byLowNibble := byByte AND 16#0F;          // 16#0B

    // 合并高低4位
    byByte := (byHighNibble SHL 4) OR byLowNibble;  // 恢复

    // ==========================================================================
    // 9. 复杂类型转换
    // ==========================================================================

    // 日期转换
    VAR dDate : DATE; END_VAR
    VAR sDate : STRING(20); END_VAR

    dDate := D#2024-01-15;
    // 日期转字符串取决于平台实现

    // 时间转换
    VAR todTime : TIME_OF_DAY; END_VAR
    todTime := TOD#12:30:45;
    // 时间转字符串取决于平台实现

    // ==========================================================================
    // 10. 安全转换（带范围检查）
    // ==========================================================================

    VAR
        inputValue : INT := 500;
        safeByte : BYTE;
    END_VAR

    // 转换为BYTE时进行范围检查
    IF inputValue >= 0 AND inputValue <= 255 THEN
        safeByte := INT_TO_BYTE(inputValue);
    ELSE
        safeByte := 0;  // 默认值或错误处理
    END_IF

    // ==========================================================================
    // 11. 类型转换在实际应用中的示例
    // ==========================================================================

    // 模拟量处理: INT (0-27648) -> REAL (0-100%)
    VAR iRaw : INT := 13824; END_VAR
    VAR rPercent : REAL; END_VAR

    rPercent := INT_TO_REAL(iRaw) / 27648.0 * 100.0;  // 50%

    // REAL (0-100%) -> INT (0-27648)
    rPercent := 75.0;
    iRaw := REAL_TO_INT(rPercent / 100.0 * 27648.0);   // 20736

    // 温度转换: 摄氏度 <-> 华氏度
    VAR rCelsius : REAL := 25.0; END_VAR
    VAR rFahrenheit : REAL; END_VAR

    rFahrenheit := rCelsius * 9.0 / 5.0 + 32.0;  // 77.0

    rCelsius := (rFahrenheit - 32.0) * 5.0 / 9.0;  // 25.0

END_PROGRAM
